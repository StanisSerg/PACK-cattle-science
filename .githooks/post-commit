#!/bin/bash
#
# Post-commit hook для PACK-cattle-science
# Автоматически запускает проверку сущностей после коммита SoTA
#

# Проверяем, был ли коммит в 06-sota
if git diff-tree --no-commit-id --name-only -r HEAD | grep -q "06-sota"; then
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  📝 Обнаружен новый SoTA"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    echo "Запускаю проверку сущностей..."
    echo ""
    
    # Запускаем проверку
    ./scripts/post-sota-check.sh --last
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  💡 Следующие шаги:"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    echo "1. Проверьте рекомендации выше"
    echo "2. Для обновления связей выполните:"
    echo "   python3 scripts/update-entity-links.py <sota_id>"
    echo ""
    echo "3. Затем: git add -A && git commit --amend"
    echo ""
fi
